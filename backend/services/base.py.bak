import requests
import pybreaker
from typing import Optional, Dict, Any

class BaseHttpService:
    def __init__(self, timeout: int = 15, breaker_name: str = None):
        self.timeout = timeout
        if breaker_name:
            self.breaker = pybreaker.CircuitBreaker(
                fail_max=3,
                reset_timeout=30,
                name=breaker_name
            )
        else:
            self.breaker = None

    def _get(self, url: str, params: Dict = None, headers: Dict = None) -> Optional[requests.Response]:
        try:
            if self.breaker:
                return self.breaker.call(
                    requests.get,
                    url, params=params, headers=headers, timeout=self.timeout
                )
            else:
                return requests.get(url, params=params, headers=headers, timeout=self.timeout)
        except Exception:
            return None

    def _post(self, url: str, json_data: Dict = None, headers: Dict = None) -> Optional[requests.Response]:
        try:
            if self.breaker:
                return self.breaker.call(
                    requests.post,
                    url, json=json_data, headers=headers, timeout=self.timeout
                )
            else:
                return requests.post(url, json=json_data, headers=headers, timeout=self.timeout)
        except Exception:
            return None
